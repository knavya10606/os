#include <stdio.h>

int main() {
    int frames = 3, pages[] = {1,2,3,4,1,2,5,1,2,3,4,5};
    int n = 12, i, j, k, fault = 0;
    int f[3], time[3], counter = 0;

    for(i = 0; i < frames; i++) {
        f[i] = -1;
        time[i] = 0;
    }

    for(i = 0; i < n; i++) {
        int found = 0;
        for(j = 0; j < frames; j++) {
            if(f[j] == pages[i]) {
                found = 1;
                time[j] = ++counter;
            }
        }

        if(!found) {
            int lru = 0;
            for(j = 1; j < frames; j++) {
                if(time[j] < time[lru]) lru = j;
            }
            f[lru] = pages[i];
            time[lru] = ++counter;
            fault++;
        }
    }

    printf("LRU Page Faults = %d", fault);
    return 0;
}
