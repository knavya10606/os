#include <stdio.h>

int main() {
    int i, n, time, remain, tq;
    int burst[20], rem_bt[20];
    int waiting[20], turnaround[20];
    float avg_wait = 0, avg_turn = 0;

    printf("Enter number of processes: ");
    scanf("%d", &n);

    remain = n;

    for(i = 0; i < n; i++) {
        printf("Enter Burst Time for Process %d: ", i + 1);
        scanf("%d", &burst[i]);
        rem_bt[i] = burst[i];
    }

    printf("Enter Time Quantum: ");
    scanf("%d", &tq);

    time = 0;

    while(remain != 0) {
        for(i = 0; i < n; i++) {
            if(rem_bt[i] > 0) {
                if(rem_bt[i] <= tq) {
                    time += rem_bt[i];
                    waiting[i] = time - burst[i];
                    rem_bt[i] = 0;
                    remain--;
                } else {
                    rem_bt[i] -= tq;
                    time += tq;
                }
            }
        }
    }

    for(i = 0; i < n; i++) {
        turnaround[i] = burst[i] + waiting[i];
        avg_wait += waiting[i];
        avg_turn += turnaround[i];
    }

    printf("\nProcess\tBurst Time\tWaiting Time\tTurnaround Time\n");

    for(i = 0; i < n; i++) {
        printf("P%d\t%d\t\t%d\t\t%d\n", i + 1, burst[i], waiting[i], turnaround[i]);
    }

    printf("\nAverage Waiting Time = %.2f", avg_wait / n);
    printf("\nAverage Turnaround Time = %.2f\n", avg_turn / n);

    return 0;
}
