#include <stdio.h>

int main() {
    int n, i, j, pos, temp;
    int burst[20], waiting[20], turnaround[20];
    float avg_wait = 0, avg_turn = 0;

    printf("Enter number of processes: ");
    scanf("%d", &n);

    for(i = 0; i < n; i++) {
        printf("Enter Burst Time for Process %d: ", i + 1);
        scanf("%d", &burst[i]);
    }

    for(i = 0; i < n; i++) {
        pos = i;
        for(j = i + 1; j < n; j++) {
            if(burst[j] < burst[pos])
                pos = j;
        }

        temp = burst[i];
        burst[i] = burst[pos];
        burst[pos] = temp;
    }

    waiting[0] = 0;

    for(i = 1; i < n; i++) {
        waiting[i] = waiting[i - 1] + burst[i - 1];
    }

    for(i = 0; i < n; i++) {
        turnaround[i] = waiting[i] + burst[i];
        avg_wait += waiting[i];
        avg_turn += turnaround[i];
    }

    printf("\nProcess\tBurst Time\tWaiting Time\tTurnaround Time\n");

    for(i = 0; i < n; i++) {
        printf("P%d\t%d\t\t%d\t\t%d\n", i + 1, burst[i], waiting[i], turnaround[i]);
    }

    printf("\nAverage Waiting Time = %.2f", avg_wait / n);
    printf("\nAverage Turnaround Time = %.2f\n", avg_turn / n);

    return 0;
}
